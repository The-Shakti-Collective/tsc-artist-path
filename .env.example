# The Artist Path — copy to .env.local for local dev

NEXT_PUBLIC_SITE_URL=http://localhost:3010
# Optional — defaults to TSC website application wizard
# NEXT_PUBLIC_APPLY_URL=https://theshakticollective.in/artist-path
NEXT_PUBLIC_TSC_WEBSITE_URL=https://theshakticollective.in
# Optional — Microsoft Clarity project ID (Settings → Overview in Clarity dashboard)
NEXT_PUBLIC_CLARITY_PROJECT_ID=
# Optional — privacy policy URL for Clarity footer disclosure link
# NEXT_PUBLIC_PRIVACY_POLICY_URL=https://theshakticollective.in/privacy

# Server-side — Platform API submission (never expose secret to client)
TSC_API_URL=http://localhost:4000/api
ARTIST_PATH_WEBHOOK_SECRET=shared-with-platform-api

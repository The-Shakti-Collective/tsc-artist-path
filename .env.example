# The Artist Path (theartistpath.in)
# Copy to .env.local for local dev. Commit this file; never commit .env.local.
# Full guide: docs/ANALYTICS_AND_PRIVACY.md

# --- Site URL ---
NEXT_PUBLIC_SITE_URL=http://localhost:3010

# --- Microsoft Clarity ---
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# --- Privacy policy (footer disclosure link) ---
# Default in code is /privacy on this host; override for absolute URL if needed
NEXT_PUBLIC_PRIVACY_POLICY_URL=https://theartistpath.in/privacy

# --- Links to main TSC site ---
NEXT_PUBLIC_TSC_WEBSITE_URL=https://theshakticollective.in
NEXT_PUBLIC_APPLY_URL=https://theshakticollective.in/artist-path

# --- Server-side Platform API (never expose secret to client) ---
TSC_API_URL=http://localhost:4000/api
ARTIST_PATH_WEBHOOK_SECRET=shared-with-platform-api
